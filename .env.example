# Server
PORT=3000

# Tu correo — se incluye en el body del webhook de Zapier
CONTACT_EMAIL=squiroz1@uc.cl

# Google Service Account – download JSON from GCP → IAM → Service Accounts → Keys
# The service account must have edit access to the target Google Sheet.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# Base64-encode the private_key from the JSON:
#   node -e "require('dotenv/config'); console.log(Buffer.from(process.env.GOOGLE_PRIVATE_KEY).toString('base64'))"
# Then paste the output here (single line, no quotes needed).
GOOGLE_PRIVATE_KEY_B64=your_base64_encoded_private_key

# Google Sheet shared with the service account (Editor). The SA creates a new tab per request.
GOOGLE_SHEET_ID=your_spreadsheet_id

